<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nightfall.englishnova.search.mapper.SearchStudyFocusMapper">

    <select id="loadStudyFocusCleanupRows" resultType="com.nightfall.englishnova.search.domain.vo.StudyFocusCleanupVo">
        SELECT id, focus_label
        FROM study_focus_areas
    </select>

    <update id="updateStudyFocusCleanup">
        UPDATE study_focus_areas
        SET focus_label = #{focusLabel}
        WHERE id = #{id}
    </update>
</mapper>
